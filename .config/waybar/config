{
        "layer": "top",
        "position": "top",
        "reload_style_on_change": true,
        "modules-left": ["hyprland/workspaces", "tray"],
        "modules-center": ["clock"],
        "modules-right": ["group/expand", "bluetooth", "backlight", "network", "wireplumber", "battery", "custom/notification"],


        "hyprland/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "active": "´äæ",
                "default": "´äæ",
                "empty": "´äæ"
            },
            "persistent-workspaces": {
                "*": [ 1,2,3 ]
            }
        },

        "custom/notification": {
            "tooltip": false,
            "format": "¯ÜÉ",
            "on-click": "uwsm app -- swaync-client -t -sw",
            "escape": true
