        },

        "custom/expand": {
            "format": "´ää",
            "tooltip": false
        },

        "custom/endpoint":{
            "format": "|",
            "tooltip": false
        },

        "group/expand": {
            "orientation": "horizontal",
            "drawer": {
                "transition-duration": 600,
                "transition-to-left": true,
                "click-to-reveal": true
            },
            "modules": ["custom/expand","cpu","memory","temperature","custom/endpoint"]
        },

        "cpu": {
