            "tooltip-format-ethernet": "{ifname} ­ƒûº ",
            "on-click": "uwsm app -- ghostty --title='nmtui' -e nmtui"
        },

        "wireplumber": {
            "format": "{icon}",
            "format-muted": "¾░Øƒ",
            "format-icons": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"],
